{
  "extends": "@subf/config/tsconfig-lib",
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["ESNext", "DOM", "DOM.Iterable", "WebWorker"],
    "strict": false,
    "noUncheckedIndexedAccess": false,
    "paths": {
      "wa-sqlite": ["./wa-sqlite/src/sqlite-api.js"],
      "wa-sqlite/src": ["./wa-sqlite/src"],
      "wa-sqlite/src/*": ["./wa-sqlite/src/*"],
      "wa-sqlite/*": ["./wa-sqlite/*"]
    },
    "types": ["@types/node"]
  },
  "include": ["src", "wa-sqlite/src/types/**/*.d.ts"]
}
