{
  "name": "@subframe7536/sqlite-wasm",
  "type": "module",
  "version": "0.5.8",
  "description": "Typesafe wa-sqlite wrapper, persist data to IndexedDB or OPFS",
  "author": "subframe7536",
  "license": "MIT",
  "repository": "https://github.com/subframe7536/sqlite-wasm",
  "keywords": [
    "typescript",
    "sqlite",
    "wasm",
    "IndexedDB"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./idb": "./dist/idb.js",
    "./idb-memory": "./dist/idb-memory.js",
    "./opfs": "./dist/opfs.js",
    "./fs-handle": "./dist/fs-handle.js",
    "./constant": "./dist/constant.js",
    "./wasm": "./dist/wa-sqlite.wasm",
    "./wasm-async": "./dist/wa-sqlite-async.wasm",
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "typesVersions": {
    "*": {
      "idb": [
        "./dist/idb.d.ts"
      ],
      "idb-memory": [
        "./dist/idb-memory.d.ts"
      ],
      "opfs": [
        "./dist/opfs.d.ts"
      ],
      "fs-handle": [
        "./dist/fs-handle.d.ts"
      ],
      "constant": [
        "./dist/constant.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "tsc --noEmit && oxlint --fix ./src",
    "format": "oxfmt",
    "dev": "vite serve playground",
    "build": "tsdown",
    "update": "bun run download.ts",
    "release": "bun run lint && bun run build && bumpp --all"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@subf/config": "^0.2.1",
    "@types/node": "^22.18.6",
    "bumpp": "^10.2.3",
    "ofetch": "^1.4.1",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "tar": "^7.5.1",
    "tsdown": "^0.21.8",
    "typescript": "^5.9.2",
    "uuidv7": "^1.0.2",
    "vite": "^8.0.0",
    "zen-mitt": "^3.1.0"
  },
  "packageManager": "bun@1.2.13"
}
